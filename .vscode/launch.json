{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Node: Results debugger",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "address": "localhost",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "remoteRoot": "/app",
      "localRoot": "${workspaceFolder}/result"
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "e:/Docker/example-voting-app/gitops",
      "program": "e:/Docker/example-voting-app/gitops/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}